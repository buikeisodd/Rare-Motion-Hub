{
  "expo": {
    "name": "Starlight Station",
    "slug": "starlight-station",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "raremotionhub",
    "jsEngine": "jsc",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raremotionhub.mobile"
    },
    "android": {
      "package": "com.raremotionhub.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#050505"
      }
    },
    "extra": {
      "apiUrl": "https://rare-motion-hub.onrender.com"
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Starlight Station to choose a profile picture from your library."
        }
      ]
    ]
  }
}
